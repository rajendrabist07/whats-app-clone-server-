NODE_ENV=development
PORT=5001
CLIENT_URL=http://localhost:5173
# CLIENT_URLS=https://your-extra-frontend-domain.vercel.app

MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/whatsapp-mern

JWT_SECRET=replace_with_strong_access_token_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_strong_refresh_token_secret
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECRET=replace_with_strong_cookie_secret

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

LOG_LEVEL=info
